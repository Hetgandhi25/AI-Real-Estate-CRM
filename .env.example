# API
VITE_API_BASE_URL=http://localhost:4000/api
VITE_API_TIMEOUT=30000

# Auth (frontend session storage)
VITE_AUTH_TOKEN_KEY=yandox_access_token
VITE_AUTH_REFRESH_TOKEN_KEY=yandox_refresh_token

# Development
# When true, uses mock session and skips API auth enforcement
VITE_MOCK_AUTH=false
VITE_ENABLE_QUERY_DEVTOOLS=true

# App
VITE_APP_NAME="Ishan Technologies"
