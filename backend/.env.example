NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://user:password@localhost:5432/propertycrm
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=5

JWT_ACCESS_TOKEN_SECRET=replace_me_with_a_secure_32_character_string
JWT_REFRESH_TOKEN_SECRET=replace_me_with_another_secure_32_character_string
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_NAME=refresh_token

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:latest

META_WA_ACCESS_TOKEN=replace_me_with_meta_token
META_WA_PHONE_NUMBER_ID=replace_me_with_phone_id
META_WA_VERIFY_TOKEN=replace_me_with_verify_token
META_APP_SECRET=replace_me_with_app_secret
